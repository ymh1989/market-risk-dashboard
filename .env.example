# Telegram bot token from BotFather.
TELEGRAM_BOT_TOKEN=

# Telegram chat id for the recipient, group, or channel.
TELEGRAM_CHAT_ID=

# Digest defaults. The launchd installer uses NEWS_DIGEST_HOUR/MINUTE.
NEWS_DIGEST_LOOKBACK_HOURS=24
NEWS_DIGEST_TOP_PER_TOPIC=4
NEWS_DIGEST_MAX_ITEMS=20
NEWS_DIGEST_HOUR=8
NEWS_DIGEST_MINUTE=30

# 시장리스크 대시보드 한국 표준시 예약
LOCAL_MARKET_UPDATE_TIMES=07:30,12:30,15:35
LOCAL_MARKET_UPDATE_SATURDAY_TIMES=07:30
LOCAL_MARKET_UPDATE_FULL_TIMES=07:30,15:35
